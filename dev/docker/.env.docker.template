# Docker Development Environment Configuration
# This file is automatically copied to .env.docker when running docker-dev
#
# All variables have sensible defaults. Only uncomment and modify
# values if you need to customize the development environment.

# Instance number for port isolation (0 = default ports, no offset)
# Set via: dev docker set-instance <number>
# SOLEI_DOCKER_INSTANCE=

# Database credentials (defaults work out of the box)
# SOLEI_POSTGRES_USER=polar
# SOLEI_POSTGRES_PWD=polar
# SOLEI_POSTGRES_DATABASE=polar
# SOLEI_POSTGRES_READ_USER=polar_read
# SOLEI_POSTGRES_READ_PWD=polar

# MinIO credentials (defaults work out of the box)
# SOLEI_MINIO_USER=polar
# SOLEI_MINIO_PWD=polarpolar
# SOLEI_AWS_ACCESS_KEY_ID=polar-development
# SOLEI_AWS_SECRET_ACCESS_KEY=polar123456789
# SOLEI_S3_FILES_BUCKET_NAME=polar-s3
# SOLEI_S3_FILES_PUBLIC_BUCKET_NAME=polar-s3-public

# Optional: GitHub integration (for full OAuth features)
# SOLEI_GITHUB_CLIENT_ID=
# SOLEI_GITHUB_CLIENT_SECRET=
# SOLEI_GITHUB_APP_NAMESPACE=

# Optional: Stripe integration (for payment features)
# SOLEI_STRIPE_SECRET_KEY=
# SOLEI_STRIPE_PUBLISHABLE_KEY=
# SOLEI_STRIPE_WEBHOOK_SECRET=
# SOLEI_STRIPE_CONNECT_WEBHOOK_SECRET=

# Optional: Prometheus remote write URL
# SOLEI_PROMETHEUS_REMOTE_WRITE_URL=
