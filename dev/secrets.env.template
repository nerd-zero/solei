# Polar Development Secrets
# Copy to ~/.config/polar/secrets.env and fill in values
#
# This file is used to share secrets across multiple Git worktrees.
# Run ./dev/setup-environment to automatically merge these into server/.env

# GitHub OAuth - create app at https://github.com/settings/apps
# Or run: ./dev/setup-environment --setup-github-app
SOLEI_GITHUB_CLIENT_ID=
SOLEI_GITHUB_CLIENT_SECRET=
SOLEI_GITHUB_APP_WEBHOOK_SECRET=
SOLEI_GITHUB_APP_IDENTIFIER=
SOLEI_GITHUB_APP_PRIVATE_KEY=
SOLEI_GITHUB_APP_NAMESPACE=

# GitHub Repository Benefits App (usually same as above)
SOLEI_GITHUB_REPOSITORY_BENEFITS_APP_NAMESPACE=
SOLEI_GITHUB_REPOSITORY_BENEFITS_APP_IDENTIFIER=
SOLEI_GITHUB_REPOSITORY_BENEFITS_APP_PRIVATE_KEY=
SOLEI_GITHUB_REPOSITORY_BENEFITS_CLIENT_ID=
SOLEI_GITHUB_REPOSITORY_BENEFITS_CLIENT_SECRET=

# Stripe - from https://dashboard.stripe.com/test/apikeys
SOLEI_STRIPE_SECRET_KEY=
SOLEI_STRIPE_PUBLISHABLE_KEY=
SOLEI_STRIPE_WEBHOOK_SECRET=
SOLEI_STRIPE_CONNECT_WEBHOOK_SECRET=
